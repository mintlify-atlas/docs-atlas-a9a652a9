  "keyFeatures": [
    "70+ predefined CSS animations",
    "Granular control with utility classes (delay, duration, easing, iteration)",
    "View timeline and scroll timeline support",
    "Advanced cubic bezier easing functions",
    "Steps/retro animation support",
    "CSS-only implementation (no JavaScript)",
    "Tree-shakeable and performance optimized"
