              "animations/fade",
              "animations/slide",
              "animations/zoom-scale",
              "animations/rotate",
              "animations/flip",
              "animations/movement",
              "animations/interactive"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "customization/duration",
              "customization/delay",
              "customization/easing",
              "customization/iteration",
              "customization/fill-modes",
              "customization/steps"
            ]
          },
          {
