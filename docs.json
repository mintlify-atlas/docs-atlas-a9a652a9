{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Tailwind Animations",
  "theme": "palm",
  "colors": {
    "primary": "#8b5cf6",
    "light": "#a78bfa",
    "dark": "#7c3aed"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/midudev/tailwind-animations"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/midudev/tailwind-animations"
    }
  },
